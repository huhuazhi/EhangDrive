<Window x:Class="EhangNAS_Sync.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:EhangNAS_Sync"
        Title="亿航Drive" Width="680" Height="720"
        Icon="app.ico"
        WindowStartupLocation="CenterScreen"
        MinWidth="500" MinHeight="600"
        Background="#F5F7FA"
        Closing="Window_Closing">
    <Window.Resources>
        <!-- 空字符串隐藏转换器 -->
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <local:StringToVisibilityConverter x:Key="StringToVisibility"/>
        <!-- 进度条状态颜色转换 -->
        <Style x:Key="TransferProgress" TargetType="ProgressBar">
            <Setter Property="Height" Value="14"/>
            <Setter Property="Foreground" Value="#1A73E8"/>
            <Setter Property="Background" Value="#E8E8E8"/>
        </Style>
    </Window.Resources>

    <Grid>
        <TabControl Margin="8" BorderThickness="0" Background="Transparent">
            <!-- ═══════ 同步 Tab ═══════ -->
            <TabItem Header="  同步  " FontSize="14" Padding="12,6">
                <Grid Margin="4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" MinHeight="100"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*" MinHeight="100"/>
                    </Grid.RowDefinitions>

                    <!-- ─── 上半区：传输进度 ─── -->
                    <Border Grid.Row="0" Background="White" CornerRadius="6" Padding="12"
                            Margin="0,4,0,2">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.08"/>
                        </Border.Effect>
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="传输任务" FontSize="13"
                                           FontWeight="SemiBold" Foreground="#444"/>
                                <TextBlock x:Name="TxtPendingCount" FontSize="13"
                                           Foreground="#888" Margin="8,0,0,0"/>
                            </StackPanel>
                            <ListView x:Name="LvTransfers" BorderThickness="0"
                                      Background="Transparent"
                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Margin" Value="0"/>
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,3">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="60"/>
                                                <ColumnDefinition Width="70"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding DirectionText}"
                                                       FontSize="12" Foreground="{Binding DirectionColor}"
                                                       VerticalAlignment="Center" Width="48"/>
                                            <StackPanel Grid.Column="1" Margin="6,0">
                                                <TextBlock Text="{Binding FileName}" FontSize="12"
                                                           Foreground="#333" TextTrimming="CharacterEllipsis"/>
                                                <ProgressBar Value="{Binding Progress}" Maximum="100"
                                                             Style="{StaticResource TransferProgress}"
                                                             Foreground="{Binding StatusColor}"
                                                             Margin="0,3,0,0"/>
                                                <TextBlock Text="{Binding Speed}" FontSize="10"
                                                           Foreground="#999" Margin="0,2,0,0"
                                                           Visibility="{Binding Speed, Converter={StaticResource StringToVisibility}}"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="2" Text="{Binding ProgressText}"
                                                       FontSize="11" Foreground="#666"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Right"/>
                                            <TextBlock Grid.Column="3" Text="{Binding StatusText}"
                                                       FontSize="11" Foreground="{Binding StatusColor}"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Right"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </DockPanel>
                    </Border>

                    <GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch"
                                  Background="Transparent" Cursor="SizeNS"/>

                    <!-- ─── 下半区：同步日志 ─── -->
                    <Border Grid.Row="2" Background="White" CornerRadius="6" Padding="12"
                            Margin="0,2,0,4">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.08"/>
                        </Border.Effect>
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="同步日志" FontSize="13"
                                       FontWeight="SemiBold" Foreground="#444" Margin="0,0,0,8"/>
                            <ListBox x:Name="LbLogs" BorderThickness="0"
                                     Background="Transparent"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding DisplayText}" FontSize="12"
                                                   Foreground="#555" Margin="0,1"
                                                   TextWrapping="Wrap"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ═══════ 设置 Tab ═══════ -->
            <TabItem Header="  设置  " FontSize="14" Padding="12,6">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="4">
                    <StackPanel>
                        <!-- 账户信息 -->
                        <Border Background="White" CornerRadius="6" Padding="20,16"
                                Margin="0,4,0,8">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.08"/>
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="账户信息" FontSize="14" FontWeight="SemiBold"
                                           Foreground="#333" Margin="0,0,0,12"/>
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="服务器：" FontSize="13" Foreground="#555"/>
                                    <TextBlock x:Name="TxtSettingServer" Grid.Column="1"
                                               FontSize="13" Foreground="#333"/>
                                </Grid>
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="用户名：" FontSize="13" Foreground="#555"/>
                                    <TextBlock x:Name="TxtSettingUsername" Grid.Column="1"
                                               FontSize="13" Foreground="#333"/>
                                </Grid>
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="登录状态：" FontSize="13" Foreground="#555"/>
                                    <TextBlock x:Name="TxtSettingLoginStatus" Grid.Column="1"
                                               FontSize="13" Foreground="#27AE60" Text="已登录"/>
                                </Grid>
                                <Button x:Name="BtnLogout" Content="登出" Width="80" Height="30"
                                        HorizontalAlignment="Left" Margin="0,8,0,0"
                                        FontSize="13" Cursor="Hand"
                                        Background="#E74C3C" Foreground="White" BorderThickness="0"
                                        Click="BtnLogout_Click"/>
                            </StackPanel>
                        </Border>

                        <!-- 同步设置 -->
                        <Border Background="White" CornerRadius="6" Padding="20,16"
                                Margin="0,0,0,8">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.08"/>
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="同步设置" FontSize="14" FontWeight="SemiBold"
                                           Foreground="#333" Margin="0,0,0,12"/>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="同步目录：" FontSize="13" Foreground="#555"
                                               VerticalAlignment="Center"/>
                                    <TextBlock x:Name="TxtSettingSyncFolder" Grid.Column="1"
                                               FontSize="13" Foreground="#333"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"/>
                                    <Button x:Name="BtnChangeSyncFolder" Grid.Column="2"
                                            Content="更改" Width="60" Height="28"
                                            FontSize="12" Cursor="Hand" Margin="8,0,0,0"
                                            Background="#1A73E8" Foreground="White"
                                            BorderThickness="0"
                                            Click="BtnChangeSyncFolder_Click"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- 已注册客户端 -->
                        <Border Background="White" CornerRadius="6" Padding="20,16"
                                Margin="0,0,0,8">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.08"/>
                            </Border.Effect>
                            <StackPanel>
                                <DockPanel Margin="0,0,0,12">
                                    <TextBlock Text="已注册客户端" FontSize="14" FontWeight="SemiBold"
                                               Foreground="#333" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="TxtClientCount" FontSize="13" Foreground="#888"
                                               Margin="8,0,0,0" VerticalAlignment="Center"/>
                                    <Button x:Name="BtnRefreshClients" Content="刷新" Width="50" Height="26"
                                            FontSize="12" Cursor="Hand" HorizontalAlignment="Right"
                                            Background="#1A73E8" Foreground="White" BorderThickness="0"
                                            Click="BtnRefreshClients_Click"/>
                                </DockPanel>
                                <ListView x:Name="LvClients" BorderThickness="1" BorderBrush="#E0E0E0"
                                          Background="Transparent" MaxHeight="180"
                                          ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                    <ListView.View>
                                        <GridView>
                                            <GridViewColumn Header="主机名" Width="140"
                                                            DisplayMemberBinding="{Binding Hostname}"/>
                                            <GridViewColumn Header="IP" Width="120"
                                                            DisplayMemberBinding="{Binding Ip}"/>
                                            <GridViewColumn Header="本机" Width="45">
                                                <GridViewColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding IsCurrentText}" FontSize="12"
                                                                   Foreground="#1A73E8" FontWeight="Bold"/>
                                                    </DataTemplate>
                                                </GridViewColumn.CellTemplate>
                                            </GridViewColumn>
                                            <GridViewColumn Header="操作" Width="60">
                                                <GridViewColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Button Content="删除" FontSize="11" Cursor="Hand"
                                                                Width="44" Height="22"
                                                                Background="#E74C3C" Foreground="White"
                                                                BorderThickness="0"
                                                                Visibility="{Binding DeleteVisibility}"
                                                                Tag="{Binding ClientId}"
                                                                Click="BtnDeleteClient_Click"/>
                                                    </DataTemplate>
                                                </GridViewColumn.CellTemplate>
                                            </GridViewColumn>
                                        </GridView>
                                    </ListView.View>
                                </ListView>
                            </StackPanel>
                        </Border>

                        <!-- 通用设置 -->
                        <Border Background="White" CornerRadius="6" Padding="20,16"
                                Margin="0,0,0,8">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.08"/>
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="通用设置" FontSize="14" FontWeight="SemiBold"
                                           Foreground="#333" Margin="0,0,0,12"/>
                                <CheckBox x:Name="ChkAutoStart" Content="开机自动启动"
                                          FontSize="13" Margin="0,0,0,8"
                                          Checked="ChkAutoStart_Changed"
                                          Unchecked="ChkAutoStart_Changed"/>
                                <CheckBox x:Name="ChkAutoLogin" Content="自动登录"
                                          FontSize="13" Margin="0,0,0,4"
                                          Checked="ChkAutoLoginSetting_Changed"
                                          Unchecked="ChkAutoLoginSetting_Changed"/>
                            </StackPanel>
                        </Border>

                        <!-- 关于 -->
                        <Border Background="White" CornerRadius="6" Padding="20,16"
                                Margin="0,0,0,8">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.08"/>
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="关于" FontSize="14" FontWeight="SemiBold"
                                           Foreground="#333" Margin="0,0,0,8"/>
                                <TextBlock FontSize="12" Foreground="#888"
                                           Text="亿航Drive v1.0 — 文件按需同步客户端"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</Window>

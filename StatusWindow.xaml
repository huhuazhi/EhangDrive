<Window x:Class="EhangNAS_Sync.StatusWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="EhangNAS 同步"
        Width="400" Height="220"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#EEF2F7"
        Closing="Window_Closing">
    <Grid>
        <Border Background="White" CornerRadius="6" Padding="28,24"
                Margin="20" VerticalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect BlurRadius="16" ShadowDepth="2" Opacity="0.12" Color="#000"/>
            </Border.Effect>
            <StackPanel>
                <TextBlock Text="✅ EhangNAS 同步已运行" FontSize="17" FontWeight="SemiBold"
                           Foreground="#1A73E8" HorizontalAlignment="Center" Margin="0,0,0,14"/>

                <TextBlock x:Name="TxtInfo" FontSize="13" Foreground="#555"
                           TextWrapping="Wrap" LineHeight="22"
                           HorizontalAlignment="Center" TextAlignment="Center"
                           Margin="0,0,0,16"/>

                <TextBlock Text="关闭此窗口将断开同步连接" FontSize="11"
                           Foreground="#999" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
